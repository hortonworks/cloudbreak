{
  "cluster": {
    "blueprintName": "7.3.2 - SDX light duty template with Atlas, HMS, Ranger and their dependent services, but no HDFS and HBASE",
    "validateBlueprint": false
  },
  "customDomain": {
    "domainName": "cloudera.site",
    "hostgroupNameAsHostname": true
  },
  "instanceGroups": [
    {
      "name": "idbroker",
      "template": {
        "instanceType": "t3.medium",
        "fallbackInstanceTypes": [ "t3a.medium", "t2.medium" ],
        "attachedVolumes": [
          {
            "count": 0,
            "type": "standard"
          }
        ]
      },
      "nodeCount": 1,
      "type": "CORE",
      "recoveryMode": "MANUAL",
      "recipeNames": []
    },
    {
      "name": "master",
      "template": {
        "instanceType": "r5.2xlarge",
        "fallbackInstanceTypes": [ "r5a.2xlarge", "r6i.2xlarge" ],
        "attachedVolumes": [
          {
            "count": 1,
            "size": 512,
            "type": "gp3"
          }
        ]
      },
      "nodeCount": 1,
      "type": "GATEWAY",
      "recoveryMode": "MANUAL",
      "recipeNames": []
    }
  ]
}
