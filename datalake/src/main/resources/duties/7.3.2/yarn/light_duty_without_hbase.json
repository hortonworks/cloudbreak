{
  "cluster": {
    "blueprintName": "7.3.2 - SDX light duty template with Atlas, HMS, Ranger and their dependent services, but no HDFS and HBASE",
    "validateBlueprint": false
  },
  "customDomain": {
    "domainName": "cloudera.site",
    "hostgroupNameAsHostname": true
  },
  "instanceGroups": [
    {
      "name": "idbroker",
      "template": {
        "yarn": {
          "cpus": 4,
          "memory": 16384
        }
      },
      "nodeCount": 1,
      "type": "CORE"
    },
    {
      "name": "master",
      "template": {
        "yarn": {
          "cpus": 32,
          "memory": 65536
        }
      },
      "nodeCount": 1,
      "type": "GATEWAY"
    }
  ]
}
