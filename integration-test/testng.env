# Spring Boot externalized config — load this file in IntelliJ Run Configuration → Modify options → Environment variables
# (or use the EnvFile plugin). Maps to integration-test/src/main/resources/application.yml via relaxed binding.
#
# Reference: https://docs.spring.io/spring-boot/reference/features/external-config.html

# --- basic config ---
INTEGRATIONTEST_CLOUDPROVIDER=MOCK # AWS, AZURE, GCP, MOCK

# --- personal config ---
INTEGRATIONTEST_USER_CRN=
INTEGRATIONTEST_USER_NAME=
INTEGRATIONTEST_USER_ACCESSKEY=
INTEGRATIONTEST_USER_SECRETKEY=
INTEGRATIONTEST_SSHPUBLICKEY=
INTEGRATIONTEST_DEFAULTPRIVATEKEYFILE=

# --- aws ---
